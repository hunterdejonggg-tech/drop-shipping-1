<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>Dropshipping Store</title>
<style>
body { font-family: Arial, sans-serif; margin: 0; padding: 0; }
header { background: #0078d4; color: white; padding: 1em; text-align: center; }
nav a { margin: 0 1em; color: white; text-decoration: none; }
.products { display: flex; flex-wrap: wrap; gap: 1em; padding: 1em; }
.product { border: 1px solid #ccc; padding: 1em; width: calc(33% - 2em); box-sizing: border-box; }
.product img { max-width: 100%; height: auto; }
@media (max-width: 600px) {
.product { width: 100%; }
}
</style>
</head>
<body>
<header>
<h1>Dropshipping Store</h1>
<nav>
<a href="index.html">Home</a>
<a href="cart.html">Cart (<span id="cart-count">0</span>)</a>
</nav>
</header>
<main>
<section class="products" id="product-list"></section>
</main>
<script>
const products = [
{ id: 1, name: "Smart Kitchen Scale", price: 25.99, image: "https://via.placeholder.com/150" },
{ id: 2, name: "Multi-purpose Vegetable Chopper", price: 19.99, image: "https://via.placeholder.com/150" },
{ id: 3, name: "Automatic Soap Dispenser", price: 29.99, image: "https://via.placeholder.com/150" }
];

function updateCartCount() {
const cart = JSON.parse(localStorage.getItem("cart") || "[]");
const count = cart.reduce((sum, item) => sum + item.qty, 0);
document.getElementById("cart-count").textContent = count;
}

function addToCart(id) {
let cart = JSON.parse(localStorage.getItem("cart") || "[]");
const index = cart.findIndex(item => item.id === id);
if (index > -1) {
cart[index].qty++;
} else {
cart.push({ id, qty: 1 });
}
localStorage.setItem("cart", JSON.stringify(cart));
updateCartCount();
alert("Added to cart");
}

function renderProducts() {
const list = document.getElementById("product-list");
products.forEach(product => {
const el = document.createElement("div");
el.className = "product";
el.innerHTML = `
<img src="${product.image}" alt="${product.name}" />
<h2>${product.name}</h2>
<p>$${product.price.toFixed(2)}</p>
<button onclick="addToCart(${product.id})">Add to Cart</button>
`;
list.appendChild(el);
});
}

renderProducts();
updateCartCount();
</script>
</body>
</html>
